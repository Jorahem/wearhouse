<div class="container py-4">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><%= link_to "Home", root_path %></li>
      <li class="breadcrumb-item"><%= link_to "Products", products_path %></li>
      <li class="breadcrumb-item active"><%= @product.name %></li>
    </ol>
  </nav>
  
  <div class="row">
    <div class="col-md-6">
      <% if @product.image_url.present? %>
        <%= image_tag @product.image_url, class: "img-fluid rounded", style: "width: 100%; max-height: 500px; object-fit: cover;" %>
      <% else %>
        <div class="bg-light rounded d-flex align-items-center justify-content-center" style="height: 500px;">
          <i class="fas fa-tshirt fa-5x text-muted"></i>
        </div>
      <% end %>
    </div>
    
    <div class="col-md-6">
      <div class="product-details">
        <h1 class="mb-3"><%= @product.name %></h1>
        
        <div class="mb-3">
          <span class="badge bg-secondary"><%= @product.category.name %></span>
        </div>
        
        <div class="mb-4">
          <h3 class="text-primary mb-0">$<%= @product.price %></h3>
          <div class="mt-2">
            <% if @product.in_stock? %>
              <span class="text-success">
                <i class="fas fa-check-circle"></i> In Stock (<%= @product.stock_quantity %> available)
              </span>
            <% else %>
              <span class="text-danger">
                <i class="fas fa-times-circle"></i> Out of Stock
              </span>
            <% end %>
          </div>
        </div>
        
        <div class="mb-4">
          <h5>Description</h5>
          <p class="text-muted"><%= simple_format(@product.description) %></p>
        </div>
        
        <div class="mb-4">
          <div class="row">
            <% if @product.size.present? %>
              <div class="col-sm-6 mb-2">
                <strong>Size:</strong> <%= @product.size %>
              </div>
            <% end %>
            <% if @product.color.present? %>
              <div class="col-sm-6 mb-2">
                <strong>Color:</strong> <%= @product.color %>
              </div>
            <% end %>
          </div>
        </div>
        
        <% if user_signed_in? %>
          <% if @product.in_stock? %>
            <%= form_with model: [@product, @cart_item], local: true, class: "mb-3" do |form| %>
              <div class="row align-items-end">
                <div class="col-sm-3">
                  <%= form.label :quantity, class: "form-label" %>
                  <%= form.number_field :quantity, value: 1, min: 1, max: @product.stock_quantity, class: "form-control" %>
                </div>
                <div class="col-sm-9">
                  <%= form.submit "Add to Cart", class: "btn btn-primary btn-lg" %>
                </div>
              </div>
            <% end %>
          <% else %>
            <button class="btn btn-secondary btn-lg" disabled>
              <i class="fas fa-times-circle"></i> Out of Stock
            </button>
          <% end %>
        <% else %>
          <div class="alert alert-info">
            <%= link_to "Please login", new_user_session_path, class: "alert-link" %> to add items to cart.
          </div>
        <% end %>
        
        <div class="mt-4">
          <%= link_to "← Back to Products", products_path, class: "btn btn-outline-secondary" %>
        </div>
      </div>
    </div>
  </div>
  
  <!-- Related Products -->
  <div class="mt-5">
    <hr>
    <h3 class="mb-4">You might also like</h3>
    <div class="row">
      <% @product.category.products.where.not(id: @product.id).available.limit(4).each do |related_product| %>
        <div class="col-lg-3 col-md-6 mb-4">
          <div class="card h-100">
            <% if related_product.image_url.present? %>
              <%= image_tag related_product.image_url, class: "card-img-top", style: "height: 200px; object-fit: cover;" %>
            <% else %>
              <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 200px;">
                <i class="fas fa-tshirt fa-3x text-muted"></i>
              </div>
            <% end %>
            <div class="card-body">
              <h6 class="card-title"><%= related_product.name %></h6>
              <p class="card-text text-primary">$<%= related_product.price %></p>
              <%= link_to "View", product_path(related_product), class: "btn btn-sm btn-outline-primary" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
