<div class="container py-4">
  <h2 class="mb-4">
    <i class="fas fa-list-alt"></i> Order History
  </h2>
  
  <% if @orders.any? %>
    <% @orders.each do |order| %>
      <div class="card mb-4">
        <div class="card-header">
          <div class="row align-items-center">
            <div class="col">
              <h6 class="mb-0">Order #<%= order.id %></h6>
              <small class="text-muted">Placed on <%= order.created_at.strftime("%B %d, %Y at %I:%M %p") %></small>
            </div>
            <div class="col-auto">
              <span class="badge bg-<%= order.pending? ? 'warning' : order.processing? ? 'info' : order.shipped? ? 'primary' : order.delivered? ? 'success' : 'secondary' %> text-<%= order.delivered? ? 'dark' : 'light' %>">
                <%= order.status.capitalize %>
              </span>
            </div>
            <div class="col-auto">
              <h6 class="mb-0 text-primary">$<%= order.total %></h6>
            </div>
          </div>
        </div>
        
        <div class="card-body">
          <div class="row">
            <div class="col-md-8">
              <h6>Items Ordered:</h6>
              <% order.order_items.each do |item| %>
                <div class="d-flex align-items-center mb-2">
                  <% if item.product.image_url.present? %>
                    <%= image_tag item.product.image_url, class: "rounded me-3", style: "width: 50px; height: 50px; object-fit: cover;" %>
                  <% else %>
                    <div class="bg-light rounded me-3 d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                      <i class="fas fa-tshirt text-muted"></i>
                    </div>
                  <% end %>
                  <div>
                    <div class="fw-medium"><%= item.product.name %></div>
                    <small class="text-muted">Qty: <%= item.quantity %> × $<%= item.price %> = $<%= item.total_price %></small>
                  </div>
                </div>
              <% end %>
            </div>
            
            <div class="col-md-4">
              <h6>Shipping Address:</h6>
              <p class="text-muted small"><%= simple_format(order.shipping_address) %></p>
              
              <div class="mt-3">
                <%= link_to "View Details", order_path(order), class: "btn btn-outline-primary btn-sm" %>
              </div>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  <% else %>
    <div class="text-center py-5">
      <i class="fas fa-list-alt fa-3x text-muted mb-3"></i>
      <h4>No orders yet</h4>
      <p class="text-muted">You haven't placed any orders yet. Start shopping to see your orders here.</p>
      <%= link_to "Browse Products", products_path, class: "btn btn-primary btn-lg" %>
    </div>
  <% end %>
</div>
