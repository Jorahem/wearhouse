<div class="container py-4">
  <h2 class="mb-4">
    <i class="fas fa-shopping-cart"></i> Shopping Cart
  </h2>
  
  <% if @cart_items.any? %>
    <div class="row">
      <div class="col-lg-8">
        <div class="card">
          <div class="card-body">
            <% @cart_items.each do |cart_item| %>
              <div class="row align-items-center border-bottom py-3">
                <div class="col-md-2">
                  <% if cart_item.product.image_url.present? %>
                    <%= image_tag cart_item.product.image_url, class: "img-fluid rounded", style: "height: 80px; object-fit: cover;" %>
                  <% else %>
                    <div class="bg-light rounded d-flex align-items-center justify-content-center" style="height: 80px;">
                      <i class="fas fa-tshirt fa-2x text-muted"></i>
                    </div>
                  <% end %>
                </div>
                
                <div class="col-md-4">
                  <h6 class="mb-1"><%= cart_item.product.name %></h6>
                  <small class="text-muted"><%= cart_item.product.category.name %></small><br>
                  <% if cart_item.product.size.present? %>
                    <small class="text-muted">Size: <%= cart_item.product.size %></small><br>
                  <% end %>
                  <% if cart_item.product.color.present? %>
                    <small class="text-muted">Color: <%= cart_item.product.color %></small>
                  <% end %>
                </div>
                
                <div class="col-md-2">
                  <span class="fw-bold">$<%= cart_item.product.price %></span>
                </div>
                
                <div class="col-md-2">
                  <%= form_with model: cart_item, method: :patch, local: true do |form| %>
                    <%= form.number_field :quantity, value: cart_item.quantity, min: 1, max: cart_item.product.stock_quantity, class: "form-control form-control-sm", onchange: "this.form.submit();" %>
                  <% end %>
                </div>
                
                <div class="col-md-1">
                  <span class="fw-bold text-primary">$<%= cart_item.total_price %></span>
                </div>
                
                <div class="col-md-1">
                  <%= link_to cart_item_path(cart_item), data: { "turbo-method": :delete, "turbo-confirm": "Remove this item from cart?" }, 
                      class: "btn btn-outline-danger btn-sm" do %>
                    <i class="fas fa-trash"></i>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      </div>
      
      <div class="col-lg-4">
        <div class="card">
          <div class="card-header">
            <h5 class="mb-0">Order Summary</h5>
          </div>
          <div class="card-body">
            <div class="d-flex justify-content-between mb-3">
              <span>Subtotal (<%= @cart_items.sum(:quantity) %> items):</span>
              <span class="fw-bold">$<%= @total %></span>
            </div>
            
            <div class="d-flex justify-content-between mb-3">
              <span>Shipping:</span>
              <span class="text-muted">Free</span>
            </div>
            
            <hr>
            
            <div class="d-flex justify-content-between mb-4">
              <span class="h5">Total:</span>
              <span class="h5 text-primary">$<%= @total %></span>
            </div>
            
            <div class="d-grid">
              <button type="button" class="btn btn-primary btn-lg" data-bs-toggle="modal" data-bs-target="#checkoutModal">
                <i class="fas fa-credit-card"></i> Proceed to Checkout
              </button>
            </div>
          </div>
        </div>
        
        <div class="mt-3">
          <%= link_to "Continue Shopping", products_path, class: "btn btn-outline-primary w-100" %>
        </div>
      </div>
    </div>
  <% else %>
    <div class="text-center py-5">
      <i class="fas fa-shopping-cart fa-3x text-muted mb-3"></i>
      <h4>Your cart is empty</h4>
      <p class="text-muted">Add some products to your cart to get started.</p>
      <%= link_to "Browse Products", products_path, class: "btn btn-primary btn-lg" %>
    </div>
  <% end %>
</div>

<!-- Checkout Modal -->
<% if @cart_items.any? %>
  <div class="modal fade" id="checkoutModal" tabindex="-1">
    <div class="modal-dialog">
      <div class="modal-content">
        <%= form_with url: orders_path, method: :post, local: true do |form| %>
          <div class="modal-header">
            <h5 class="modal-title">Checkout</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
          </div>
          <div class="modal-body">
            <div class="mb-4">
              <%= form.label :shipping_address, "Shipping Address", class: "form-label" %>
              <%= form.text_area :shipping_address, class: "form-control", rows: 4, required: true, placeholder: "Enter your complete shipping address..." %>
            </div>
            
            <div class="mb-4">
              <h6 class="form-label">Payment Method</h6>
              <div class="border rounded p-3">
                <div class="form-check mb-2">
                  <input class="form-check-input" type="radio" name="payment_method" id="credit_card" value="credit_card" checked>
                  <label class="form-check-label" for="credit_card">
                    <i class="fas fa-credit-card me-2"></i>Credit/Debit Card
                  </label>
                </div>
                <div class="form-check mb-2">
                  <input class="form-check-input" type="radio" name="payment_method" id="paypal" value="paypal">
                  <label class="form-check-label" for="paypal">
                    <i class="fab fa-paypal me-2"></i>PayPal
                  </label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="radio" name="payment_method" id="cod" value="cod">
                  <label class="form-check-label" for="cod">
                    <i class="fas fa-money-bill me-2"></i>Cash on Delivery
                  </label>
                </div>
                <small class="text-muted">Note: This is a demo store. No actual payment will be processed.</small>
              </div>
            </div>
            
            <div class="alert alert-info">
              <h6><i class="fas fa-shopping-cart me-2"></i>Order Summary</h6>
              <div class="row">
                <div class="col-6">
                  <strong>Items:</strong>
                  <br><strong>Subtotal:</strong>
                  <br><strong>Shipping:</strong>
                  <br><strong>Tax:</strong>
                </div>
                <div class="col-6 text-end">
                  <%= @cart_items.sum(:quantity) %>
                  <br>$<%= @total %>
                  <br><span class="text-success">FREE</span>
                  <br>$0.00
                </div>
              </div>
              <hr>
              <div class="d-flex justify-content-between">
                <strong class="h6">Total Amount:</strong>
                <strong class="h6 text-primary">$<%= @total %></strong>
              </div>
            </div>
            
            <div class="alert alert-warning">
              <small><i class="fas fa-info-circle me-1"></i>
              <strong>Demo Mode:</strong> This is a demonstration store. Your order will be recorded but no actual payment will be processed and no items will be shipped.
              </small>
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
            <%= form.submit "Place Order", class: "btn btn-primary" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
<% end %>
