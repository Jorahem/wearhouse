<!-- Hero Section -->
<div class="bg-primary text-white py-5">
  <div class="container">
    <div class="row align-items-center">
      <div class="col-lg-6">
        <h1 class="display-4 fw-bold">Welcome to Wearhouse</h1>
        <p class="lead">Discover the latest fashion trends and find your perfect style. Shop from our extensive collection of high-quality clothing for men and women.</p>
        <%= link_to "Shop Now", products_path, class: "btn btn-light btn-lg" %>
      </div>
      <div class="col-lg-6">
        <div class="text-center">
          <i class="fas fa-tshirt display-1"></i>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Categories Section -->
<div class="container py-5">
  <h2 class="text-center mb-5">Shop by Category</h2>
  <div class="row">
    <% @categories.each do |category| %>
      <div class="col-md-4 mb-4">
        <div class="card h-100 text-center">
          <div class="card-body">
            <i class="fas fa-tag fa-3x text-primary mb-3"></i>
            <h5 class="card-title"><%= category.name %></h5>
            <p class="card-text"><%= category.description %></p>
            <%= link_to "Browse #{category.name}", products_path(category_id: category.id), class: "btn btn-outline-primary" %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>

<!-- Featured Products Section -->
<div class="bg-light py-5">
  <div class="container">
    <h2 class="text-center mb-5">Featured Products</h2>
    <div class="row">
      <% @featured_products.each do |product| %>
        <div class="col-lg-3 col-md-4 col-sm-6 mb-4">
          <div class="card h-100">
            <% if product.image_url.present? %>
              <%= image_tag product.image_url, class: "card-img-top", style: "height: 200px; object-fit: cover;" %>
            <% else %>
              <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 200px;">
                <i class="fas fa-tshirt fa-3x text-muted"></i>
              </div>
            <% end %>
            <div class="card-body d-flex flex-column">
              <h6 class="card-title"><%= product.name %></h6>
              <p class="card-text text-muted small"><%= product.category.name %></p>
              <p class="card-text"><%= truncate(product.description, length: 60) %></p>
              <div class="mt-auto">
                <div class="d-flex justify-content-between align-items-center">
                  <span class="h6 text-primary">$<%= product.price %></span>
                  <%= link_to "View", product_path(product), class: "btn btn-sm btn-outline-primary" %>
                </div>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
    <div class="text-center mt-4">
      <%= link_to "View All Products", products_path, class: "btn btn-primary btn-lg" %>
    </div>
  </div>
</div>
