<div class="container py-4">
  <div class="row">
    <!-- Sidebar -->
    <div class="col-md-3">
      <div class="card">
        <div class="card-header">
          <h5>Filter Products</h5>
        </div>
        <div class="card-body">
          <%= form_tag products_path, method: :get, local: true, class: "mb-3" do %>
            <%= text_field_tag :search, params[:search], placeholder: "Search products...", class: "form-control mb-3" %>
            <%= submit_tag "Search", class: "btn btn-primary btn-sm w-100" %>
          <% end %>
          
          <hr>
          
          <h6>Categories</h6>
          <div class="list-group list-group-flush">
            <%= link_to "All Products", products_path, class: "list-group-item list-group-item-action #{'active' unless params[:category_id]}" %>
            <% @categories.each do |category| %>
              <%= link_to category.name, products_path(category_id: category.id), 
                  class: "list-group-item list-group-item-action #{'active' if params[:category_id] == category.id.to_s}" %>
            <% end %>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Products Grid -->
    <div class="col-md-9">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Products</h2>
        <span class="text-muted"><%= @products.count %> products found</span>
      </div>
      
      <% if @products.any? %>
        <div class="row">
          <% @products.each do |product| %>
            <div class="col-lg-4 col-md-6 mb-4">
              <div class="card h-100">
                <% if product.image_url.present? %>
                  <%= image_tag product.image_url, class: "card-img-top", style: "height: 250px; object-fit: cover;" %>
                <% else %>
                  <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 250px;">
                    <i class="fas fa-tshirt fa-4x text-muted"></i>
                  </div>
                <% end %>
                <div class="card-body d-flex flex-column">
                  <h6 class="card-title"><%= product.name %></h6>
                  <p class="card-text text-muted small">
                    <i class="fas fa-tag"></i> <%= product.category.name %>
                  </p>
                  <p class="card-text"><%= truncate(product.description, length: 80) %></p>
                  
                  <div class="mt-auto">
                    <div class="row align-items-center">
                      <div class="col">
                        <span class="h5 text-primary mb-0">$<%= product.price %></span><br>
                        <small class="text-muted">
                          <% if product.in_stock? %>
                            <i class="fas fa-check-circle text-success"></i> In Stock (<%= product.stock_quantity %>)
                          <% else %>
                            <i class="fas fa-times-circle text-danger"></i> Out of Stock
                          <% end %>
                        </small>
                      </div>
                      <div class="col-auto">
                        <%= link_to "View Details", product_path(product), class: "btn btn-primary btn-sm" %>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="text-center py-5">
          <i class="fas fa-search fa-3x text-muted mb-3"></i>
          <h4>No products found</h4>
          <p class="text-muted">Try adjusting your search or filter criteria.</p>
          <%= link_to "Browse All Products", products_path, class: "btn btn-primary" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
